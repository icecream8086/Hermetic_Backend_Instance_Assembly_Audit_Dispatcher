{
  "name": "nginx",
  "description": "Nginx web server demo — lightweight, ports 80, TCP readiness check",

  "singleton": true,

  "container": {
    "region": "local",
    "containers": [
      {
        "name": "nginx",
        "image": "docker.io/library/nginx:latest",
        "ports": [
          { "containerPort": 80, "protocol": "TCP" }
        ],
        "resources": {
          "limits": { "cpu": 0.5, "memory": 128 }
        }
      }
    ],
    "restartPolicy": "Always"
  },

  "healthChecks": [
    {
      "name": "nginx-ready",
      "target": "container:nginx",
      "type": "readiness",
      "probe": { "tcpSocket": { "port": 80 } },
      "periodSeconds": 5,
      "initialDelaySeconds": 2
    }
  ],

  "network": {
    "publicIp": { "allocate": false }
  }
}
