{
  "name": "hbi-aad",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-features.mjs && node scripts/generate-templates.mjs && node scripts/generate-instance-templates.mjs",
    "predev": "npm run generate",
    "predev:worker": "npm run generate",
    "pretypecheck": "npm run generate && npm run gen:sdk",
    "predeploy": "npm run generate",
    "dev": "tsx watch src/dev.ts",
    "dev:worker": "wrangler dev --log-level debug",
    "typecheck": "tsc --noEmit",
    "typecheck:next": "node_modules/typescript7/bin/tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "docs:http": "tsx scripts/export-http.ts",
    "docs:openapi": "tsx scripts/export-openapi.ts",
    "gen:sdk": "npx openapi-typescript openapi.json -o src/generated/sdk.d.ts",
    "gen:all": "npm run docs:openapi && npm run gen:sdk",
    "docs:arch": "npx tsx scripts/arch-doc.ts",
    "docs:gen": "npx tsx scripts/gendoc.ts",
    "tail": "wrangler tail --format pretty",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "reset": "node scripts/reset.mjs",
    "map": "npm run map:deps && npm run map:calls && npm run map:class && npm run map:deadcode",
    "map:deps": "npx madge --ts-config tsconfig.json --extensions ts --json --no-spinner --no-color src/index.ts > dependency-graph.json && npx tsx scripts/gen-module-metrics.ts",
    "map:calls": "npx tsx scripts/callgraph.ts",
    "map:class": "npx tsx scripts/metrics.ts",
    "map:deadcode": "npx knip --no-exit-code",
    "map:arch": "depcruise --output-type err-long src",
    "stats": "cloc src --by-file --include-lang=TypeScript --exclude-dir=node_modules",
    "stats:json": "cloc src --json --include-lang=TypeScript --exclude-dir=node_modules > code-stats.json"
  },
  "hbi-aad": {
    "features": {
      "info": "/",
      "users": "/api/users",
      "permission": "/api/permissions",
      "system-group": "/api/system-groups",
      "template": "/api/templates",
      "pod": "/api/pods",
      "platforms": "/api/platforms",
      "network": "/api/networks",
      "topology": "/api/topology",
      "subnet": "/api/subnets",
      "volume": "/api/volumes",
      "container-secret": "/api/container-secrets",
      "images": "/api/images",
      "actions": "/api/actions",
      "instances": "/api/instances",
      "security": "/api/security",
      "storage": "/api/storage"
    }
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "hono": "^4.12.23",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^2.0.2",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "0x": "^6.0.0",
    "cloc": "^2.6.0-cloc",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.6.0",
    "fast-check": "^4.8.0",
    "knip": "^6.16.0",
    "madge": "^8.0.0",
    "openapi-typescript": "^7.13.0",
    "pactum": "^3.9.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "typescript7": "npm:typescript@7.0.1-rc",
    "vitest": "^4.1.6",
    "wrangler": "^4.91.0"
  },
  "__comment__": "typescript7 is TS 7.0 RC (ESM-only). madge (CJS) cannot load it — keep typescript@5.9.3 as primary. Use 'npx -p typescript7 tsc --noEmit' for RC typecheck or 'npm run typecheck:next'. Verified: tsc 7.0.1-rc → 0 errors, madge → 0 circular deps, vitest → all pass."
}
