{
  "name": "hbi-aad",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-features.mjs",
    "predev": "npm run generate",
    "predev:worker": "npm run generate",
    "pretypecheck": "npm run generate",
    "predeploy": "npm run generate",
    "dev": "tsx watch src/dev.ts",
    "dev:worker": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "docs:http": "tsx scripts/export-http.ts",
    "tail": "wrangler tail --format pretty",
    "reset": "node scripts/reset.mjs"
  },
  "hbi-aad": {
    "features": {
      "info": "/",
      "users": "/api/users",
      "permission": "/api/permissions",
      "system-group": "/api/system-groups"
    }
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@vitest/coverage-v8": "^4.1.6",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@hono/node-server": "^2.0.2",
    "@types/node": "^22.19.19",
    "pactum": "^3.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.91.0"
  }
}
